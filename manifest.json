{
  "name": "GDEI Coxcomb (Polar Area)",
  "id": "gdei-coxcomb",
  "organization": "MLA Consulting",
  "description": "True Coxcomb chart for GDEI factors (Leadership, Infrastructure, Faculty Capacity, Student Engagement).",

  "data": {
    "datasets": [
      {
        "id": "main",
        "label": "GDEI Coxcomb",
        "dimensions": [
          {
            "id": "factor",
            "label": "Factor (Leadership, Infrastructure, Faculty, Students)",
            "type": "TEXT"
          }
        ],
        "metrics": [
          {
            "id": "value",
            "label": "Average score (1–3)",
            "type": "NUMBER"
          }
        ]
      }
    ]
  },

  "style": {
    "maxValue": {
      "label": "Max scale value",
      "type": "NUMBER",
      "defaultValue": 3
    },
    "showRing": {
      "label": "Show outer reference ring",
      "type": "BOOLEAN",
      "defaultValue": true
    }
  },

  "resources": {
    "js": [
      {
        "url": "index.html",
        "useIframe": true
      }
    ]
  }
}
